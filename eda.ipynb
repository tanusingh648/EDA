
import seaborn as sns
import matplotlib.pyplot as plt

import kagglehub
import pandas as pd
import os

# Download dataset
path = kagglehub.dataset_download(
    "shrutimehta/zomato-restaurants-data"
)

# List files
files = os.listdir(path)
print(files)

# Get CSV file
csv_file = [f for f in files if f.endswith(".csv")][0]

# Read CSV
df = pd.read_csv(
    os.path.join(path, csv_file),
    encoding="latin1"
)

print(df.head())


print(df.shape)
print(df.columns.tolist())

df.drop_duplicates(inplace=True)

sns.countplot(y='Country Code', data=df)
plt.title("Restaurant Count by Country")
plt.show()
